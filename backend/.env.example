# Application environment (development|uat|staging|production)
APP_ENV=development

# Database
DATABASE_URL=postgresql+psycopg2://mystic:mysticpass@localhost:5432/mystic

# AWS Bedrock Configuration
AWS_REGION=us-east-1
# Local-only convenience values. Do not use static AWS keys in uat/staging/production;
# use IAM roles for ECS tasks instead.
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_SESSION_TOKEN=

# Bedrock models (legacy/default path; persona orchestration should be used for user-facing generation)
BEDROCK_PREVIEW_MODEL=us.amazon.nova-lite-v1:0
BEDROCK_FULL_MODEL=us.amazon.nova-pro-v1:0

# Persona orchestration path
# Set this to the exact Bedrock Claude Opus model ID granted in your account/region.
BEDROCK_MODEL_CLAUDE_OPUS=global.anthropic.claude-opus-4-5-20251101-v1:0
MYSTIC_USE_PERSONA_ORCHESTRATION=true
MYSTIC_HARD_FAIL_QUALITY_GATES=true
MYSTIC_STRUCTURED_OUTPUT_MODE=json_schema
MYSTIC_LLM_PROFILE_PREVIEW_MODEL=global.anthropic.claude-opus-4-5-20251101-v1:0
MYSTIC_LLM_PROFILE_FULL_MODEL=global.anthropic.claude-opus-4-5-20251101-v1:0
MYSTIC_LLM_PROFILE_DAILY_MODEL=global.anthropic.claude-opus-4-5-20251101-v1:0
MYSTIC_LLM_PROFILE_GROUNDED_MODEL=global.anthropic.claude-opus-4-5-20251101-v1:0

# S3 Configuration (for palm images)
S3_BUCKET_NAME=mystic-palm-images

# Authentication
JWT_SECRET_KEY=your_jwt_secret_key_here_change_in_production

# Application Settings
DEBUG=false
LOG_LEVEL=INFO
# Comma-separated list for browser app origins.
# In production, leave nothing implicit: set this explicitly to your public web origins.
CORS_ALLOWED_ORIGINS=

# Explicitly allow the temporary development-only purchase/subscription bypass.
ALLOW_DEV_PURCHASE_BYPASS=false

# Store verification
# GOOGLE_SERVICE_ACCOUNT_JSON may be the raw JSON credential or a file path to it.
GOOGLE_PLAY_PACKAGE_NAME=
GOOGLE_SERVICE_ACCOUNT_JSON=
