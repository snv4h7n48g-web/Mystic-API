# Application environment (development|production)
APP_ENV=development

# Database
DATABASE_URL=postgresql+psycopg2://mystic:mysticpass@localhost:5432/mystic

# AWS Bedrock Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# Bedrock Models (legacy/default path)
BEDROCK_PREVIEW_MODEL=us.amazon.nova-lite-v1:0
BEDROCK_FULL_MODEL=us.amazon.nova-pro-v1:0

# Persona orchestration path
# Set this to the exact Bedrock Claude Opus model ID you want to use in prod.
# Example placeholder only — replace with the exact ID granted in your account/region.
BEDROCK_MODEL_CLAUDE_OPUS=
MYSTIC_USE_PERSONA_ORCHESTRATION=false
MYSTIC_LLM_PROFILE_PREVIEW_MODEL=
MYSTIC_LLM_PROFILE_FULL_MODEL=
MYSTIC_LLM_PROFILE_DAILY_MODEL=
MYSTIC_LLM_PROFILE_GROUNDED_MODEL=

# S3 Configuration (for palm images)
S3_BUCKET_NAME=mystic-palm-images

# Authentication
JWT_SECRET_KEY=your_jwt_secret_key_here_change_in_production

# Application Settings
DEBUG=false
LOG_LEVEL=INFO
# Comma-separated list for browser app origins.
# In production, leave nothing implicit: set this explicitly to your public web origins.
CORS_ALLOWED_ORIGINS=

# Explicitly allow the temporary development-only purchase/subscription bypass
ALLOW_DEV_PURCHASE_BYPASS=false
